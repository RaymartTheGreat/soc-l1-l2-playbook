        "language": "jsx",
        "code": "index=omar source=\"WinEventLog:Microsoft-Windows-PowerShell/Operational\" EventCode=4104AND ((ScriptBlockText=*-noni* *iex* *New-Object*) OR (ScriptBlockText=*-ep* *bypass* *-Enc*) OR\n    (ScriptBlockText=*powershell* *reg* *add* *HKCU\\\\software\\\\microsoft\\\\windows\\\\currentversion\\\\run*) OR\n    (ScriptBlockText=*bypass* *-noprofile* *-windowstyle* *hidden* *new-object* *system.net.webclient* *.download*) OR\n    (ScriptBlockText=*iex* *New-Object* *Net.WebClient* *.Download*))\n| table Computer, ScriptBlockText, UserID"
      },
      {
        "language": "jsx",
        "code": "index=omar sourcetype=__your__windows__sysmon__sourcetype \n(EventCode=1 OR EventCode=1102) Image=*wevtutil* CommandLine=*cl* (CommandLine=*System* \nOR CommandLine=*Security* OR CommandLine=*Setup* OR CommandLine=*Application*)"
      },
      {
        "language": "jsx",
        "code": "| tstats count values(Processes.user) as user, values(Processes.parent_process) as parent_process, min(_time) as firstTime, max(_time) as lastTime from datamodel=Endpoint.Processes where (Processes.process_name=net.exe OR Processes.process_name=net1.exe) AND (Processes.process=*localgroup* OR Processes.process=*/add* OR Processes.process=*user*) by Processes.process, Processes.process_name, Processes.dest| `create_local_admin_accounts_using_net_exe_filter`"
      },
      {
        "language": "jsx",
