        "language": "jsx",
        "code": "index=omar sourcetype=winxsecurity user=* user!=\"\"| stats count(eval(action=\"success\")) as successes, count(eval(action=\"failure\")) as failures by user, ComputerName\n| where successes>0 AND failures>100\n\nindex=omar source=\"WinEventLog:Security\" EventCode=4625| bin _time span=5m| stats count by _time, user, host, src, action\n| where count >= 5\n\nindex=omar source=\"/var/log/auth.log\" \"Failed password\"| bin _time span=5m| stats count by _time, user, host, src, action\n| where count >= 5"
      },
      {
        "language": "jsx",
        "code": "index=omar EventCode=4625| stats count by src_ip, user\n| where count > 10| sort -count\n| table src_ip, user, count"
      },
      {
        "language": "jsx",
        "code": "index=omar sourcetype=web_auth_logs\n| stats count by user, src_ip\n| where count > 10| sort -count\n| table user, src_ip, count"
      },
      {
        "language": "jsx",
        "code": "index=omar sourcetype=windows EventCode=4625 user=\"admin*\"| stats count by user, src_ip\n| where count > 5| sort -count\n| table user, src_ip, count"
      }
    ],
    "importantCommands": [
